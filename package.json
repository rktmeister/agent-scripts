{
  "name": "agent-scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "mkdir -p bin && for f in *.ts; do bun build \"$f\" --compile --outfile \"bin/${f%.ts}\"; done && cp scripts/committer bin/committer && cp scripts/gwt bin/gwt",
    "build:tool": "mkdir -p bin && bun build \"$TOOL.ts\" --compile --outfile \"bin/$TOOL\"",
    "install-bin": "cp bin/* ~/.local/bin/"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "commander": "^13.1.0",
    "jsdom": "^27.0.1",
    "puppeteer-core": "^24.34.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
